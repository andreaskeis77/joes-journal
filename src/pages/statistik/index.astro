---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import StatCard from "../../components/StatCard.astro";
import {
  restaurants,
  reviews,
  recipes,
  cocktails,
  equipment,
  topCities,
  alcoholFreeCocktailCount,
  ownedEquipmentCount,
  wishlistEquipmentCount,
} from "../../data/stub";

const totalRestaurants = restaurants.length;
const reviewedRestaurants = restaurants.filter((r) => r.status === "reviewed").length;
const watchlistRestaurants = restaurants.filter(
  (r) => r.status === "wishlist" || r.status === "planned",
).length;

const restaurantStats = [
  { label: "Restaurants insgesamt", value: totalRestaurants, icon: "/assets/stats/stat-icon-restaurants-total.svg" },
  { label: "Mit Kritik", value: reviewedRestaurants, icon: "/assets/stats/stat-icon-reviews-total.svg" },
  { label: "Auf der Watchlist", value: watchlistRestaurants, icon: "/assets/stats/stat-icon-restaurants-watchlist.svg" },
  { label: "Top-Städte", value: topCities.length, icon: "/assets/stats/stat-icon-top-cities.svg" },
];

const contentStats = [
  { label: "Kritiken", value: reviews.length, icon: "/assets/stats/stat-icon-reviews-total.svg" },
  { label: "Rezepte", value: recipes.length, icon: "/assets/stats/stat-icon-recipes-total.svg" },
  { label: "Cocktails", value: cocktails.length, icon: "/assets/stats/stat-icon-cocktails-total.svg" },
  { label: "Alkoholfreie Cocktails", value: alcoholFreeCocktailCount, icon: "/assets/stats/stat-icon-cocktails-total.svg" },
];

const equipmentStats = [
  { label: "Geräte insgesamt", value: equipment.length, icon: "/assets/stats/stat-icon-equipment-owned.svg" },
  { label: "Im Besitz", value: ownedEquipmentCount, icon: "/assets/stats/stat-icon-equipment-owned.svg" },
  { label: "Auf der Wunschliste", value: wishlistEquipmentCount, icon: "/assets/stats/stat-icon-equipment-owned.svg" },
];

const cityMax = topCities[0]?.count ?? 1;
---

<BaseLayout
  title="Statistik"
  description="Wo das Journal steht: Restaurants, Kritiken, Rezepte, Cocktails und Geräte in Zahlen."
>
  <PageHeader
    eyebrow="Statistik"
    title="Joe in Zahlen"
    lede="Vier MVP-Restaurantmetriken, plus ein Blick auf Content und Equipment."
  />

  <section class="stats-section">
    <div class="container">
      <h2>Restaurants</h2>
      <div class="grid grid-4">
        {restaurantStats.map((stat) => <StatCard stat={stat} />)}
      </div>
    </div>
  </section>

  <section class="stats-section alt">
    <div class="container">
      <h2>Top-Städte und Regionen</h2>
      <ul class="city-list">
        {topCities.map((city) => (
          <li>
            <div class="city-row">
              <span class="city-name">{city.city}</span>
              <span class="city-count">{city.count}</span>
            </div>
            <div class="city-bar">
              <span class="city-bar-fill" style={`width: ${Math.round((city.count / cityMax) * 100)}%`}></span>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="stats-section">
    <div class="container">
      <h2>Inhalte</h2>
      <div class="grid grid-4">
        {contentStats.map((stat) => <StatCard stat={stat} />)}
      </div>
    </div>
  </section>

  <section class="stats-section alt">
    <div class="container">
      <h2>Geräte</h2>
      <div class="grid grid-3">
        {equipmentStats.map((stat) => <StatCard stat={stat} />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .stats-section { padding-block: var(--space-7); }
  .stats-section.alt { background: var(--color-footer); border-block: 1px solid var(--color-border); }

  h2 { margin: 0 0 var(--space-5); }

  .grid {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr 1fr;
  }

  @media (min-width: 700px) {
    .grid-3 { grid-template-columns: repeat(3, 1fr); }
    .grid-4 { grid-template-columns: repeat(4, 1fr); }
  }

  .city-list {
    list-style: none; margin: 0; padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 600px;
  }

  .city-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: var(--space-1);
    font-size: var(--font-size-base);
  }
  .city-name { color: var(--color-text); }
  .city-count { color: var(--color-text-muted); font-variant-numeric: tabular-nums; }

  .city-bar {
    height: 8px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    overflow: hidden;
  }
  .city-bar-fill {
    display: block;
    height: 100%;
    background: var(--color-umami-petrol);
    border-radius: 999px;
  }
</style>
