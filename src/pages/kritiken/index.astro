---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import ReviewCard from "../../components/ReviewCard.astro";
import EmptyState from "../../components/EmptyState.astro";
import { reviewsByDateDesc } from "../../data/source";
---

<BaseLayout
  title="Kritiken"
  description="Restaurantkritiken aus dem persönlichen Journal: ehrlich, ruhig, klar bewertet."
>
  <PageHeader
    eyebrow="Kritiken"
    title="Aus der Restaurant-Schreibwerkstatt"
    lede="Persönliche Restaurantkritiken mit 5-Sterne-Bewertung. Neuestes oben."
  />

  <section class="review-list">
    <div class="container">
      {
        reviewsByDateDesc.length === 0 ? (
          <EmptyState
            title="Noch keine Kritik veröffentlicht."
            description="Sobald die erste Kritik fertig ist, erscheint sie hier."
          />
        ) : (
          <div class="grid">
            {reviewsByDateDesc.map((review) => (
              <ReviewCard review={review} />
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .review-list {
    padding-block: var(--space-6) var(--space-9);
  }

  .grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: 1fr;
  }

  @media (min-width: 700px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1100px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
