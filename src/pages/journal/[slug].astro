---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  articles,
  articlesByDateDesc,
  restaurantBySlug,
  recipeBySlug,
  cocktailBySlug,
} from "../../data/source";
import type { ArticleStub } from "../../data/source";
import { sanitizeArticleHtml } from "../../lib/content/richtext";

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

interface Props {
  article: ArticleStub;
}

const { article } = Astro.props;
const publishedDate = new Date(article.publishedDate).toLocaleDateString("de-DE", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
// Body ist WYSIWYG-HTML aus Directus – vor der Ausgabe sanieren (siehe richtext.ts).
const bodyHtml = sanitizeArticleHtml(article.body);

const relatedRestaurants = article.relatedRestaurantSlugs
  .map((slug) => restaurantBySlug.get(slug))
  .filter((r) => r !== undefined);
const relatedRecipes = article.relatedRecipeSlugs
  .map((slug) => recipeBySlug.get(slug))
  .filter((r) => r !== undefined);
const relatedCocktails = article.relatedCocktailSlugs
  .map((slug) => cocktailBySlug.get(slug))
  .filter((c) => c !== undefined);
const hasRelated =
  relatedRestaurants.length > 0 || relatedRecipes.length > 0 || relatedCocktails.length > 0;

const moreArticles = articlesByDateDesc.filter((a) => a.slug !== article.slug).slice(0, 2);
---

<BaseLayout
  title={article.seoTitle ?? article.title}
  description={article.seoDescription ?? article.summary}
>
  <article class="article-detail">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/journal">Journal</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{article.title}</span>
    </nav>

    <div class="hero">
      <img src={article.image} alt="" width="1600" height="900" loading="eager" decoding="async" />
    </div>

    <header class="container head">
      <div class="head-meta">
        {article.eyebrow && <span class="eyebrow">{article.eyebrow}</span>}
        {article.eyebrow && <span aria-hidden="true">·</span>}
        <time datetime={article.publishedDate}>{publishedDate}</time>
      </div>
      <h1>{article.title}</h1>
      <p class="summary">{article.summary}</p>
    </header>

    <div class="container body" set:html={bodyHtml} />

    {
      article.tags.length > 0 && (
        <div class="container tags-wrap">
          {article.tags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )
    }

    {
      article.galleryImages.length > 0 && (
        <section class="container gallery-section">
          <h2>Galerie</h2>
          <div class="gallery">
            {article.galleryImages.map((src) => (
              <figure>
                <img src={src} alt="" loading="lazy" decoding="async" />
              </figure>
            ))}
          </div>
        </section>
      )
    }

    {
      hasRelated && (
        <section class="container related-section">
          <h2>Dazu im Journal</h2>
          <ul class="related-list">
            {relatedRestaurants.map((r) => (
              <li>
                <a href={`/restaurants/${r!.slug}`}>
                  <span class="related-kind">Restaurant</span>
                  <span class="related-title">{r!.name}</span>
                </a>
              </li>
            ))}
            {relatedRecipes.map((r) => (
              <li>
                <a href={`/rezepte/${r!.slug}`}>
                  <span class="related-kind">Rezept</span>
                  <span class="related-title">{r!.title}</span>
                </a>
              </li>
            ))}
            {relatedCocktails.map((c) => (
              <li>
                <a href={`/cocktails/${c!.slug}`}>
                  <span class="related-kind">Cocktail</span>
                  <span class="related-title">{c!.name}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      moreArticles.length > 0 && (
        <section class="container more-section">
          <h2>Weitere Beiträge</h2>
          <ul class="more-list">
            {moreArticles.map((a) => (
              <li>
                <a href={`/journal/${a.slug}`} class="more-link">
                  <img src={a.image} alt="" width="200" height="113" loading="lazy" />
                  <span>
                    <span class="more-title">{a.title}</span>
                    <span class="more-meta">{a.eyebrow ?? "Journal"}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .article-detail {
    padding-bottom: var(--space-9);
  }

  .breadcrumb {
    padding: var(--space-4) 0;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    text-align: center;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
  }

  .breadcrumb span[aria-current] {
    color: var(--color-text);
    font-weight: 500;
  }

  .hero {
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: 540px;
    overflow: hidden;
    background: var(--color-bg-warm);
  }

  .hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .head {
    padding-block: var(--space-7) var(--space-5);
    max-width: var(--max-content);
  }

  .head-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .eyebrow {
    color: var(--color-secondary);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--font-size-xs);
  }

  .head h1 {
    margin: 0 0 var(--space-4);
  }

  .summary {
    margin: 0;
    font-size: var(--font-size-lg);
    color: var(--color-text-muted);
    line-height: var(--line-body);
    max-width: 60ch;
  }

  .body {
    max-width: var(--max-content);
    padding-block: var(--space-5) var(--space-5);
  }

  .body :global(p) {
    font-size: var(--font-size-base);
    line-height: var(--line-body);
    margin: 0 0 var(--space-5);
  }

  .body :global(h2),
  .body :global(h3),
  .body :global(h4) {
    margin: var(--space-6) 0 var(--space-3);
    line-height: 1.25;
  }

  .body :global(ul),
  .body :global(ol) {
    margin: 0 0 var(--space-5);
    padding-left: var(--space-5);
  }

  .body :global(li) {
    margin-bottom: var(--space-2);
    line-height: var(--line-body);
  }

  .body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    margin: var(--space-5) 0;
  }

  .body :global(figure) {
    margin: var(--space-5) 0;
  }

  .body :global(figcaption) {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
  }

  .body :global(blockquote) {
    margin: var(--space-5) 0;
    padding-left: var(--space-4);
    border-left: 3px solid var(--color-secondary);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .body :global(a) {
    color: var(--color-secondary);
    text-decoration: underline;
  }

  .tags-wrap {
    max-width: var(--max-content);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding-bottom: var(--space-6);
  }

  .tag {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-3);
  }

  .gallery-section,
  .related-section,
  .more-section {
    padding-block: var(--space-7);
    border-top: 1px solid var(--color-border);
    max-width: var(--max-detail);
  }

  .gallery-section h2,
  .related-section h2,
  .more-section h2 {
    margin: 0 0 var(--space-5);
  }

  .gallery {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }

  .gallery figure {
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--color-bg-warm);
  }

  .gallery figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .related-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }

  .related-list a {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    color: inherit;
    text-decoration: none;
  }

  .related-list a:hover {
    border-color: var(--color-secondary);
    text-decoration: none;
  }

  .related-kind {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .related-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--font-size-base);
  }

  .more-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }

  .more-link {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    color: inherit;
    text-decoration: none;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
  }

  .more-link:hover {
    border-color: var(--color-secondary);
    text-decoration: none;
  }

  .more-link img {
    width: 96px;
    height: 54px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .more-title {
    display: block;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--font-size-base);
  }

  .more-meta {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  @media (min-width: 700px) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
    }
    .related-list {
      grid-template-columns: repeat(2, 1fr);
    }
    .more-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1000px) {
    .related-list {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
