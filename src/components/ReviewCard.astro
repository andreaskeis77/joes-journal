---
import type { ReviewStub } from "../data/source";
import { restaurantBySlug } from "../data/source";
import RatingStars from "./RatingStars.astro";

interface Props {
  review: ReviewStub;
}

const { review } = Astro.props;
const restaurant = restaurantBySlug.get(review.restaurantSlug);
const restaurantName = restaurant?.name ?? "Unbekanntes Restaurant";
const city = restaurant?.city ?? "";
const visitedDate = new Date(review.visitedOn).toLocaleDateString("de-DE", {
  year: "numeric",
  month: "long",
});
---

<article class="review-card">
  <a class="review-link" href={`/kritiken/${review.slug}`}>
    <div class="image-wrap">
      <img
        src={review.image}
        alt=""
        width="1600"
        height="1200"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="body">
      <div class="meta">
        <span class="restaurant">{restaurantName}</span>
        {city && (
          <>
            <span class="dot" aria-hidden="true">·</span>
            <span class="city">{city}</span>
          </>
        )}
        <span class="dot" aria-hidden="true">·</span>
        <time datetime={review.visitedOn}>{visitedDate}</time>
      </div>
      <h3 class="title">{review.title}</h3>
      <p class="excerpt">{review.excerpt}</p>
      <RatingStars value={review.rating} />
    </div>
  </a>
</article>

<style>
  .review-card {
    background: var(--color-card);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .review-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .review-link {
    display: flex;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
  }

  .review-link:hover {
    text-decoration: none;
  }

  .image-wrap {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bg-warm);
  }

  .image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }

  .review-card:hover .image-wrap img {
    transform: scale(1.04);
  }

  .body {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    align-items: baseline;
  }

  .restaurant {
    color: var(--color-text);
    font-weight: 500;
  }

  .dot {
    color: var(--color-border);
  }

  .title {
    margin: 0;
    font-size: var(--font-size-xl);
  }

  .excerpt {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--font-size-base);
    line-height: var(--line-body);
  }
</style>
