---
import type { RestaurantStub } from "../data/stub";
import StatusBadge from "./StatusBadge.astro";

interface Props {
  restaurant: RestaurantStub;
}

const { restaurant } = Astro.props;
const priceDisplay = "€".repeat(restaurant.priceLevel);
---

<article class="restaurant-card">
  <a class="restaurant-link" href={`/restaurants/${restaurant.slug}`}>
    <div class="image-wrap">
      <img
        src={restaurant.image}
        alt=""
        width="1600"
        height="1200"
        loading="lazy"
        decoding="async"
      />
      <span class="status-overlay">
        <StatusBadge status={restaurant.status} label={restaurant.statusLabel} />
      </span>
    </div>
    <div class="body">
      <p class="city">{restaurant.city}</p>
      <h3 class="name">{restaurant.name}</h3>
      <div class="meta">
        <span class="cuisine">{restaurant.cuisine}</span>
        <span class="dot" aria-hidden="true">·</span>
        <span class="price" aria-label={`Preisniveau ${restaurant.priceLevel} von 4`}>{priceDisplay}</span>
      </div>
    </div>
  </a>
</article>

<style>
  .restaurant-card {
    background: var(--color-card);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
    transition: transform 160ms ease, box-shadow 160ms ease;
    height: 100%;
  }

  .restaurant-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .restaurant-link {
    display: flex;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
    height: 100%;
  }
  .restaurant-link:hover {
    text-decoration: none;
  }

  .image-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bg-warm);
  }

  .image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .status-overlay {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
  }

  .body {
    padding: var(--space-5);
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .city {
    margin: 0 0 var(--space-1);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .name {
    margin: 0 0 var(--space-2);
    font-size: var(--font-size-lg);
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: baseline;
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .dot {
    color: var(--color-border);
  }

  .price {
    font-family: var(--font-ui);
    color: var(--color-text);
    letter-spacing: 0.04em;
  }
</style>
