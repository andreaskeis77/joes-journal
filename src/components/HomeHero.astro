---
interface Props {
  title?: string;
  claim?: string;
}

const {
  title = "Zum Fettigen Joe",
  claim = "Ein persönliches Journal über Restaurants, Küche, Cocktails und guten Geschmack.",
} = Astro.props;
---

<section class="hero" aria-label="Startseite">
  <picture>
    <source
      media="(max-width: 700px)"
      srcset="/assets/heroes/hero-home-mobile-restaurant-table-4x5-v01.webp"
    />
    <img
      class="hero-img"
      src="/assets/heroes/hero-home-editorial-restaurant-table-16x9-v01.webp"
      alt=""
      width="2400"
      height="1350"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  </picture>

  <div class="hero-overlay"></div>

  <div class="hero-inner container">
    <p class="eyebrow hero-eyebrow">powered by umami</p>
    <h1 class="hero-title">{title}</h1>
    <p class="hero-claim">{claim}</p>

    <form class="hero-search" role="search" action="/suche" method="get">
      <label class="visually-hidden" for="q">Globale Suche</label>
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        class="search-icon"
      >
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m20 20-3.5-3.5"></path>
      </svg>
      <input
        id="q"
        name="q"
        type="search"
        autocomplete="off"
        placeholder="Suche nach Restaurant, Stadt, Rezept, Zutat, Cocktail, Gerät…"
      />
      <button type="submit" class="btn btn-primary search-submit">Suchen</button>
    </form>

    <div class="hero-ctas">
      <a class="btn btn-primary" href="/kritiken">Neueste Kritiken</a>
      <a class="btn btn-secondary" href="/restaurants">Restaurants entdecken</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    margin-bottom: var(--space-9);
    isolation: isolate;
  }

  .hero-img {
    width: 100%;
    height: clamp(420px, 70vh, 720px);
    object-fit: cover;
    display: block;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        rgba(34, 34, 34, 0.05) 0%,
        rgba(34, 34, 34, 0.55) 60%,
        rgba(34, 34, 34, 0.72) 100%
      );
    z-index: 1;
  }

  .hero-inner {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: var(--space-7);
    color: #fff;
  }

  .hero-eyebrow {
    color: #fff;
    opacity: 0.9;
  }

  .hero-title {
    color: #fff;
    margin: 0 0 var(--space-3);
    max-width: 18ch;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
  }

  .hero-claim {
    color: rgba(255, 255, 255, 0.94);
    font-size: var(--font-size-lg);
    max-width: 52ch;
    margin: 0 0 var(--space-5);
  }

  .hero-search {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--color-surface);
    border-radius: var(--radius-md);
    padding: var(--space-2);
    box-shadow: var(--shadow-panel);
    max-width: 720px;
    margin-bottom: var(--space-5);
  }

  .hero-search .search-icon {
    color: var(--color-text-muted);
    margin-inline-start: var(--space-3);
    flex-shrink: 0;
  }

  .hero-search input {
    flex: 1;
    border: 0;
    background: transparent;
    padding: var(--space-3);
    font-family: var(--font-ui);
    font-size: var(--font-size-base);
    color: var(--color-text);
    min-width: 0;
  }

  .hero-search input:focus {
    outline: none;
  }

  .hero-search .search-submit {
    min-height: 40px;
    padding: var(--space-2) var(--space-4);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 600px) {
    .hero-search .search-submit span,
    .hero-search .search-submit {
      padding-inline: var(--space-3);
    }
    .hero-title {
      max-width: 14ch;
    }
  }
</style>
