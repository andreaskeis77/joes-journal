---
interface Props {
  value: number;
  max?: number;
}

const { value, max = 5 } = Astro.props;
const rounded = Math.round(value * 2) / 2;
const full = Math.floor(rounded);
const hasHalf = rounded - full === 0.5;
const empty = max - full - (hasHalf ? 1 : 0);
const display = value.toFixed(1).replace(".", ",");
---

<span class="rating" aria-label={`Bewertung ${display} von ${max}`}>
  <span class="stars" aria-hidden="true">
    {Array.from({ length: full }).map(() => <span class="star filled">★</span>)}
    {hasHalf && <span class="star half">★</span>}
    {Array.from({ length: empty }).map(() => <span class="star">☆</span>)}
  </span>
  <span class="rating-value">{display} / {max}</span>
</span>

<style>
  .rating {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-text);
  }
  .stars {
    color: var(--color-joe-red);
    letter-spacing: 0.05em;
    font-size: var(--font-size-base);
  }
  .star.half {
    background: linear-gradient(
      90deg,
      var(--color-joe-red) 50%,
      var(--color-border) 50%
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .rating-value {
    color: var(--color-text-muted);
  }
</style>
