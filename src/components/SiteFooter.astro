---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <img
        src="/assets/brand/brand-monogram-jj.svg"
        alt=""
        width="40"
        height="40"
        loading="lazy"
      />
      <div>
        <p class="footer-title">Zum Fettigen Joe</p>
        <p class="footer-claim">
          Ein persönliches Journal über Restaurants, Küche, Cocktails und guten Geschmack.
        </p>
      </div>
    </div>

    <div class="footer-meta">
      <p class="signature">powered by umami</p>
      <p class="copy">© {year} Zum Fettigen Joe · Privates Journal</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-footer);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-9);
    padding-block: var(--space-7);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .footer-brand {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .footer-title {
    margin: 0 0 var(--space-1);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--font-size-lg);
  }

  .footer-claim {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    max-width: 56ch;
  }

  .footer-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .signature {
    margin: 0;
    color: var(--color-secondary);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: var(--font-size-xs);
  }

  .copy {
    margin: 0;
  }

  @media (min-width: 900px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
    .footer-meta {
      flex-direction: column;
      align-items: flex-end;
      border-top: none;
      padding-top: 0;
      gap: var(--space-2);
    }
  }
</style>
