---
const navItems: Array<{ label: string; href: string }> = [
  { label: "Journal", href: "/" },
  { label: "Restaurants", href: "/restaurants" },
  { label: "Kritiken", href: "/kritiken" },
  { label: "Rezepte", href: "/rezepte" },
  { label: "Cocktails", href: "/cocktails" },
  { label: "Zutaten", href: "/zutaten" },
  { label: "Geräte", href: "/geraete" },
  { label: "Sammlungen", href: "/sammlungen" },
  { label: "Über Joe", href: "/ueber-joe" },
];

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname === href || pathname.startsWith(`${href}/`);
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="Zum Fettigen Joe – Startseite">
      <img
        class="brand-badge"
        src="/assets/brand/brand-badge-joe-round.svg"
        alt=""
        width="36"
        height="36"
        loading="eager"
        decoding="async"
      />
      <span class="brand-wordmark">
        <span class="brand-line-1">Zum Fettigen Joe</span>
        <span class="brand-line-2">powered by umami</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Hauptnavigation">
      <ul>
        {navItems.map((item) => (
          <li>
            <a href={item.href} class:list={[{ active: isActive(item.href) }]}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a class="search-link" href="/suche" aria-label="Suche">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m20 20-3.5-3.5"></path>
      </svg>
      <span class="search-label">Suche</span>
    </a>

    <input id="mobile-drawer-toggle" type="checkbox" class="drawer-toggle" aria-hidden="true" />
    <label
      class="burger"
      for="mobile-drawer-toggle"
      aria-label="Menü öffnen"
      role="button"
      tabindex="0"
    >
      <span class="burger-bar" aria-hidden="true"></span>
      <span class="burger-bar" aria-hidden="true"></span>
      <span class="burger-bar" aria-hidden="true"></span>
    </label>

    <label class="drawer-scrim" for="mobile-drawer-toggle" aria-hidden="true"></label>

    <aside class="mobile-drawer" aria-label="Mobile Navigation">
      <div class="drawer-head">
        <span class="drawer-title">Menü</span>
        <label class="drawer-close" for="mobile-drawer-toggle" aria-label="Menü schließen">
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M6 6l12 12"></path>
            <path d="M18 6L6 18"></path>
          </svg>
        </label>
      </div>
      <nav aria-label="Mobile Hauptnavigation">
        <ul>
          {navItems.map((item) => (
            <li>
              <a href={item.href} class:list={[{ active: isActive(item.href) }]}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <a class="drawer-search" href="/suche">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.5-3.5"></path>
        </svg>
        Suche
      </a>
    </aside>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: saturate(140%) blur(6px);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    min-height: 72px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text);
    font-family: var(--font-heading);
    font-weight: 600;
    text-decoration: none;
  }

  .brand:hover {
    text-decoration: none;
  }

  .brand-badge {
    width: 36px;
    height: 36px;
  }

  .brand-wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }

  .brand-line-1 {
    font-size: var(--font-size-lg);
    letter-spacing: -0.01em;
  }

  .brand-line-2 {
    font-size: var(--font-size-xs);
    color: var(--color-secondary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .site-nav {
    margin-inline-start: auto;
    display: none;
  }

  .site-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-5);
  }

  .site-nav a {
    color: var(--color-text);
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    text-decoration: none;
    padding: var(--space-2) 0;
    border-bottom: 2px solid transparent;
  }

  .site-nav a:hover,
  .site-nav a.active {
    color: var(--color-primary);
    text-decoration: none;
    border-bottom-color: var(--color-primary);
  }

  .search-link {
    margin-inline-start: auto;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-size: var(--font-size-sm);
    background: var(--color-surface);
  }

  .search-link:hover {
    border-color: var(--color-secondary);
    color: var(--color-secondary);
    text-decoration: none;
  }

  .search-label {
    display: none;
  }

  /* Mobile drawer (CSS-only checkbox hack) */
  .drawer-toggle {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .burger {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    cursor: pointer;
  }

  .burger:hover {
    border-color: var(--color-secondary);
  }

  .burger-bar {
    display: block;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
  }

  .drawer-scrim,
  .mobile-drawer {
    position: fixed;
    top: 0;
    bottom: 0;
    z-index: 50;
  }

  .drawer-scrim {
    inset: 0;
    background: rgba(34, 34, 34, 0.5);
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease;
  }

  .mobile-drawer {
    right: 0;
    width: min(85vw, 360px);
    background: var(--color-surface);
    box-shadow: var(--shadow-panel);
    transform: translateX(100%);
    transition: transform 220ms ease;
    display: flex;
    flex-direction: column;
    padding: var(--space-5);
    overflow-y: auto;
  }

  .drawer-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-5);
  }

  .drawer-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--font-size-lg);
  }

  .drawer-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    cursor: pointer;
  }

  .drawer-close:hover {
    border-color: var(--color-secondary);
    color: var(--color-secondary);
  }

  .mobile-drawer nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .mobile-drawer nav a {
    display: block;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-ui);
    font-size: var(--font-size-lg);
    color: var(--color-text);
    text-decoration: none;
  }

  .mobile-drawer nav a:hover,
  .mobile-drawer nav a.active {
    color: var(--color-primary);
    text-decoration: none;
  }

  .drawer-search {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    margin-top: var(--space-6);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    background: var(--color-text);
    color: #fff;
    font-size: var(--font-size-base);
    text-decoration: none;
  }

  .drawer-search:hover {
    background: var(--color-primary);
    text-decoration: none;
  }

  .drawer-toggle:checked ~ .drawer-scrim {
    opacity: 1;
    pointer-events: auto;
  }

  .drawer-toggle:checked ~ .mobile-drawer {
    transform: translateX(0);
  }

  @media (min-width: 700px) {
    .search-label {
      display: inline;
    }
  }

  @media (min-width: 1100px) {
    .site-nav {
      display: block;
    }
    .search-link {
      margin-inline-start: 0;
    }
    .burger {
      display: none;
    }
    .mobile-drawer,
    .drawer-scrim {
      display: none;
    }
  }
</style>
