---
import type { RestaurantStatus } from "../data/stub";

interface Props {
  status: RestaurantStatus;
  label: string;
}

const { status, label } = Astro.props;

const colors: Record<RestaurantStatus, string> = {
  wishlist: "var(--color-umami-petrol)",
  planned: "var(--color-warning)",
  visited: "var(--color-success)",
  reviewed: "var(--color-joe-red)",
};
---

<span class="status-badge" data-status={status} style={`--badge-color: ${colors[status]}`}>
  {label}
</span>

<style>
  .status-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.96);
    color: var(--badge-color);
    border: 1px solid var(--badge-color);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1.4;
  }
</style>
