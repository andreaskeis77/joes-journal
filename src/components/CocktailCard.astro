---
import type { CocktailStub } from "../data/source";

interface Props {
  cocktail: CocktailStub;
}

const { cocktail } = Astro.props;
---

<article class="cocktail-card">
  <a class="cocktail-link" href={`/cocktails/${cocktail.slug}`}>
    <div class="image-wrap">
      <img
        src={cocktail.image}
        alt={cocktail.name}
        width="1600"
        height="2000"
        loading="lazy"
        decoding="async"
      />
      {cocktail.type === "alkoholfrei" && <span class="tag tag-alkoholfrei">alkoholfrei</span>}
    </div>
    <div class="body">
      <h3>{cocktail.name}</h3>
      <p class="meta">
        <span>{cocktail.glass}</span>
        <span aria-hidden="true">·</span>
        <span>{cocktail.technique}</span>
      </p>
      <p class="flavor">{cocktail.flavorProfile}</p>
    </div>
  </a>
</article>

<style>
  .cocktail-card {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition:
      transform 160ms ease,
      box-shadow 160ms ease;
    height: 100%;
  }

  .cocktail-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .cocktail-link {
    display: flex;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
    height: 100%;
  }

  .cocktail-link:hover {
    text-decoration: none;
  }

  .image-wrap {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-bg-warm);
  }

  .image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tag {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid var(--color-umami-petrol);
    color: var(--color-umami-petrol);
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .body {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  h3 {
    margin: 0;
    font-size: var(--font-size-lg);
  }

  .meta {
    margin: 0;
    display: flex;
    gap: var(--space-2);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .flavor {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-body);
  }
</style>
