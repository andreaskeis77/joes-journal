<?xml version="1.0" encoding="UTF-8"?>
<!--
  Static-hosting config for the IIS site that serves Astro's dist/.
  Lives in public/ so Astro copies it to dist/web.config on every build.

  Two jobs:

  1) MIME types: ensure IIS serves modern static asset types (.webp, .svg,
     .woff2, .webmanifest). Without an explicit .webp map IIS returns 404 for
     those files (broken hero/cover images). <remove> precedes each <mimeMap>
     so this never throws "duplicate collection entry" if the type is already
     defined at the server level.

  2) Caching (E1.2 Komfort): by default every file is served `no-cache`, so a
     freshly rebuilt page is NEVER shown stale from the browser cache - the
     publish -> rebuild change appears immediately, no Strg+F5 needed. `no-cache`
     still allows efficient revalidation (304 via Last-Modified/ETag), it only
     forbids serving without checking. The ONE exception is Astro's
     content-hashed bundles under /_astro: their filename changes whenever their
     content changes, so they are safe to cache forever ("immutable"). Directus
     image uploads under /_uploads deliberately stay on the no-cache default
     because a "replace file" in Directus keeps the same UUID/filename - long
     caching there could show an old image.
-->
<configuration>
  <system.webServer>
    <staticContent>
      <remove fileExtension=".webp" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
      <!-- Default for HTML and all other files: always revalidate, never stale. -->
      <clientCache cacheControlMode="DisableCache" />
    </staticContent>
  </system.webServer>

  <!-- Content-hashed Astro bundles: filename changes with content, cache long. -->
  <location path="_astro">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" cacheControlCustom="public, immutable" />
      </staticContent>
    </system.webServer>
  </location>
</configuration>
