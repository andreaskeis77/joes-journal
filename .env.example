# joes-journal Astro frontend env vars.
# Copy this file to `.env` (gitignored) to override defaults.

# ----- Data source -----
# "stub"    — uses src/data/stub.ts (no Directus required; default)
# "directus" — fetches from a running Directus instance at build/dev time
JOES_DATA_SOURCE="stub"

# ----- Directus connection (used when JOES_DATA_SOURCE=directus) -----
JOES_DIRECTUS_URL="http://127.0.0.1:8055"
JOES_DIRECTUS_EMAIL="admin@example.com"
JOES_DIRECTUS_PASSWORD="change-me-locally"
